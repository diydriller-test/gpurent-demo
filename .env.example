# 로컬 실행용 환경 변수 예시
# 사용법: 이 파일을 복사한 뒤 값을 채워 넣으세요.
#   cp .env.example .env.local
# Next.js는 .env.local을 우선 로드합니다.

# LLM (/api/chat) — LangChain OpenAI 호환 엔드포인트용
OPENAI_API_KEY=

# Reranker (/api/rerank) — 업스트림 API access_token
# 우선 QWEN_API_KEY를 사용하고, 없으면 RERANK_API_KEY를 사용합니다.
QWEN_API_KEY=
# RERANK_API_KEY=

EMBEDDING_API_KEY=

